# ⚠️ 安全警告：永远不要将 .env 提交到 git！如果已经提交过包含 API key 的 .env，
#    请立即撤销泄露的 key 并重新生成。
# ⚠️ SECURITY: Never commit .env to git. If you've already committed API keys,
#    revoke them immediately and generate new ones.
#
# ⚠️ 以下所有 change-me 值在生产部署前必须修改！
# WARNING: All change-me values MUST be changed before production deployment!

# VigilOps 环境配置

# ---- 环境 ----
ENVIRONMENT=development              # 设为 "production" 启用严格安全策略（CORS、密钥校验等）

# ---- 数据库 ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vigilops
POSTGRES_USER=vigilops
POSTGRES_PASSWORD=change-me

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                      # 生产环境强烈建议设置 Redis 密码

# ---- JWT 认证 ----
# ⚠️ 生产环境必须设置！可用 python -c "import secrets; print(secrets.token_urlsafe(64))" 生成
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- 后端服务 ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ---- Agent Token HMAC 密钥 ----
# ⚠️ 生产环境必须设置！可用 python -c "import secrets; print(secrets.token_urlsafe(64))" 生成
AGENT_TOKEN_HMAC_KEY=                # Agent 令牌签名密钥，开发环境自动生成

# ---- Prometheus AlertManager Bridge ----
ALERTMANAGER_WEBHOOK_TOKEN=          # /api/v1/webhooks/alertmanager 的 Bearer token

# ---- AI 配置（可选，启用 AI 分析功能需要）----
AI_PROVIDER=deepseek
AI_API_KEY=
AI_API_BASE=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=2000
AI_AUTO_SCAN=false

# ---- MCP Server 认证（可选，启用后 MCP 工具需要 Bearer Token）----
# 可用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成
VIGILOPS_MCP_TOKEN=                  # MCP Server 认证 token，留空则禁用认证

# ---- HTTPS 配置（可选，使用 docker-compose.ssl.yml 时需要）----
DOMAIN=localhost
HTTPS_PORT=443
HTTP_PORT=80
SSL_CERT_DIR=./nginx/certs

# ---- 通知系统配置 (Notification System Configuration)----
# SSRF 防护：允许的 Webhook 域名白名单（逗号分隔），留空则不限制（仅开发环境）
WEBHOOK_ALLOWED_DOMAINS=           # 例如: api.example.com,webhook.example.com
WEBHOOK_ENABLE_SSL_VERIFICATION=true

# 通知发送配置
NOTIFICATION_MAX_RETRIES=3         # 通知发送失败最大重试次数
NOTIFICATION_TEMPLATE_CACHE_TTL=3600   # 模板缓存 TTL（秒）- 1小时
NOTIFICATION_CHANNEL_CACHE_TTL=1800    # 渠道缓存 TTL（秒）- 30分钟
NOTIFICATION_DEFAULT_COOLDOWN=300      # 默认冷却时间（秒）- 5分钟
