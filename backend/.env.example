# VigilOps 配置示例
# 复制为 .env 并按需修改

# ---------- 数据库 ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vigilops
POSTGRES_USER=vigilops
POSTGRES_PASSWORD=change-me

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                      # 生产环境强烈建议设置 Redis 密码

# ---------- AI ----------
AI_PROVIDER=deepseek
AI_API_KEY=
AI_API_BASE=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=2000
AI_AUTO_SCAN=false

# ---------- Agent 自动修复 ----------
AGENT_ENABLED=false                  # 是否启用自动修复 Agent
# ⚠️ 上线后建议先以 dry_run=true 观察一周，确认无误再设为 false
AGENT_DRY_RUN=true                   # dry-run 模式：只记录不执行
AGENT_MAX_AUTO_PER_HOUR=10           # 每小时最大自动修复次数
AGENT_NOTIFY_ON_SUCCESS=true         # 修复成功时发送通知
AGENT_NOTIFY_ON_FAILURE=true         # 修复失败/升级时发送通知

# ---------- JWT ----------
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- MCP Server ----------
VIGILOPS_MCP_ENABLED=false
VIGILOPS_MCP_HOST=127.0.0.1
VIGILOPS_MCP_PORT=8003
VIGILOPS_MCP_TOKEN=                  # 设置后开启 Bearer Token 认证
